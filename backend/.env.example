PORT=5000
NODE_ENV=development

# ── Supabase ────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (for running migrations only) ──────────────────
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ── Stripe (optional) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# ── Cloudinary (image uploads) ──────────────────────────────
# Sign up free at https://cloudinary.com — Dashboard shows all three values.
# If any of these are missing, the backend falls back to local ./uploads storage.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── SSLCommerz (payment gateway) ────────────────────────────
# Sandbox credentials: https://developer.sslcommerz.com/registration/
# For live, set SSLCOMMERZ_IS_LIVE=true and use your production store credentials.
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
SSLCOMMERZ_IS_LIVE=false

# Public base URL of this backend (used for SSLCommerz callback URLs).
# In production set this to e.g. https://api.topsell.shop
BACKEND_URL=http://localhost:5000

# ── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
