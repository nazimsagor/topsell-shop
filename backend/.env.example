# Backend server
NODE_ENV=production
PORT=5000

# CORS
# Primary frontend domain (required)
FRONTEND_URL=https://your-frontend.vercel.app
# Optional: comma-separated extra origins (custom domains, staging, etc.)
ALLOWED_ORIGINS=https://staging-your-frontend.vercel.app,https://shop.example.com
# Optional: allow Vercel preview domains (*.vercel.app)
ALLOW_VERCEL_PREVIEW=false

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Supabase (required by runtime)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Postgres (required for migration script)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
